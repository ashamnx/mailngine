{
  "$schema": "https://json.schemastore.org/web-manifest-combined.json",
  "name": "Mailngine",
  "short_name": "Mailngine",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#1A73E8",
  "description": "Reliable email delivery for developers.",
  "icons": [
    {
      "src": "/logo.svg",
      "type": "image/svg+xml",
      "sizes": "any"
    }
  ]
}
