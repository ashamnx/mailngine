[Unit]
Description=Hello Mail Background Worker
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/mailngine
EnvironmentFile=/opt/mailngine/.env
ExecStart=/opt/mailngine/bin/worker
Restart=always
RestartSec=5
LimitNOFILE=65535

NoNewPrivileges=true
ProtectHome=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
